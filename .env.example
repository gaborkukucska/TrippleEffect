# START OF FILE .env.example

# Copy this file to .env and fill in your details.
# Remove or comment out lines for providers you are not using.

###
# --- Model Filtering Tier --- **Under development!**
###

# Controls which models from *remote* providers (OpenRouter, OpenAI) are made available.
# Local providers (Ollama, LiteLLM) are always included if reachable.
# Valid options:
#   ALL  = Include all local/external discovered models (local, free and paid).
#   FREE = Include only models identified as free (currently checks for ':free' in model IDs).
#   LOCAL = Include ONLY local models
MODEL_TIER="LOCAL"

###
# --- Default Agent Setup ---
###
# DEFAULT_AGENT_PROVIDER="openrouter"
# DEFAULT_AGENT_MODEL="google/gemma-2-9b-it:free"
# DEFAULT_TEMPERATURE=0.7

###
# --- Local API Discovery ---
###

# Enable/disable scanning for local APIs (Ollama, LiteLLM, etc.)
LOCAL_API_SCAN_ENABLED=true
# Ports to check during the scan
LOCAL_API_SCAN_PORTS="11434,8000"
# Timeout (in seconds) for attempting connection to each IP/port during scan
LOCAL_API_SCAN_TIMEOUT=0.5

###
# --- Retry and Failover Settings ---
###
MAX_STREAM_RETRIES=3
RETRY_DELAY_SECONDS=5.0
MAX_FAILOVER_ATTEMPTS=3
# Max number of turns an agent can take in a single cycle before being forced into an error state.
MAX_CYCLE_TURNS=15

###
# --- Native Tool Calling ---
###
# Enable or disable the framework's use of native provider tool calling APIs where available. 
# Set to false to force raw XML tool calling.
NATIVE_TOOL_CALLING_ENABLED=true

###
# --- Context & Token Limits ---
###
# Token count threshold to trigger context summarization.
SUMMARIZER_TRIGGER_THRESHOLD=7000

# Max output tokens for specific states and agents
ADMIN_AI_LOCAL_MAX_TOKENS=4096
PM_STARTUP_STATE_MAX_TOKENS=4096
PM_WORK_STATE_MAX_TOKENS=4096
PM_MANAGE_STATE_MAX_TOKENS=4096
WORKER_STARTUP_STATE_MAX_TOKENS=1024
WORKER_DECOMPOSE_STATE_MAX_TOKENS=1024
WORKER_WORK_STATE_MAX_TOKENS=4096
WORKER_WAIT_STATE_MAX_TOKENS=512
CG_MAX_TOKENS=4000

###
# --- Ollama Specific Overrides ---
###
# Hard cap for the context window sent to Ollama (num_ctx configuration)
OLLAMA_MAX_CTX_CAP=32768
# Maximum number of concurrent connections permitted simultaneously to your Ollama node.
OLLAMA_CONCURRENCY_LIMIT=2

###
# --- System Timers & Limits ---
###
# How frequently (in seconds) the PM reassesses tasks automatically while in management standby
PM_MANAGE_CHECK_INTERVAL_SECONDS=60.0
# Global cap for workers assigned to a single PM on a project
MAX_WORKERS_PER_PM=20

###
# --- Constitutional Guardian Settings ---
###
# Controls the strictness level of the Constitutional Guardian's interventions.
# Valid options:
#   1 = Permissive (Higher threshold before blocking repeated/empty responses)
#   2 = Moderate   (Default recommended setting)
#   3 = Strict     (Lower threshold, blocks problematic behaviors faster)
CG_STRICTNESS_LEVEL=2

# Interval for the Guardian heartbeat monitor (seconds)
CG_HEARTBEAT_INTERVAL_SECONDS=60.0
# The time an agent must have made zero progress before Guardian forcefully wakes it up (seconds)
CG_STALLED_THRESHOLD_SECONDS=300.0

###
# --- LLM Provider API Keys & Configuration ---
###

# -- OpenRouter (REQUIRED if used) --
# Supports multiple keys: OPENROUTER_API_KEY, OPENROUTER_API_KEY_1, ...
# OPENROUTER_API_KEY="sk-or-v1-..."
# OPENROUTER_BASE_URL="https://openrouter.ai/api/v1" 
# OPENROUTER_REFERER="http://localhost:8000/YourAppName" 

# -- OpenAI (Optional) --
# Supports multiple keys: OPENAI_API_KEY, OPENAI_API_KEY_1, ...
# OPENAI_API_KEY="sk-..."
# OPENAI_BASE_URL="" 

# -- LiteLLM (Optional - for local proxy/models) --
# LITELLM_API_KEY="" # Only needed if your LiteLLM instance requires a master key

# -- Other Providers (Optional - Add if needed) --
# ANTHROPIC_API_KEY="sk-ant-..."
# GOOGLE_API_KEY="..."
# DEEPSEEK_API_KEY="..."

###
# --- Tool Configuration ---
###

# GitHub Tool (Optional) - Requires 'repo' scope for full functionality
# GITHUB_ACCESS_TOKEN=""

# --- SearXNG Search URL ---
# Add your SearXNG instance URL here.
SEARXNG_URL="http://192.168.0.1:8080/"
SEARXNG_FORMAT="json"

###
# --- Project/Session Configuration ---
###
# Optional: Define where project session data is stored. Defaults to 'projects/' in the root.
# PROJECTS_BASE_DIR="./my_projects"

###
# --- Logging Configuration (Optional) ---
###
# Valid options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=CRITICAL

